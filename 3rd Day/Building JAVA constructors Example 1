class Car {
    String model;
    int year;

    Car() {
        model = "Default Model";
        year = 2025;
    }

    void display() {
        System.out.println("Car Model: " + model + ", Year: " + year);
    }
}

public class Main {
    public static void main(String[] args) {
        Car myCar = new Car();
        myCar.display();
    }
}
