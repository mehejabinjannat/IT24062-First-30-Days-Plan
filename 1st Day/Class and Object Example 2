class Student {
    String name;
    int id;

    void showDetails() {
        System.out.println("Student Name: " + name);
        System.out.println("Student ID: " + id);
    }
}

public class Main {
    public static void main(String[] args) {
        Student s1 = new Student();

        s1.name = "Rahim";
        s1.id = 101;

        s1.showDetails();
    }
}
