class Car {
    String color;
    String model;
    int year;

    void displayInfo() {
        System.out.println("Color: " + color);
        System.out.println("Model: " + model);
        System.out.println("Year: " + year);
    }
}

public class Main {
    public static void main(String[] args) {
        Car myCar = new Car();

        myCar.color = "Red";
        myCar.model = "Toyota";
        myCar.year = 2020;

        myCar.displayInfo();
    }
}
