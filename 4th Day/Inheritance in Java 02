class Vehicle {
    String brand;
    int speed;

    void start() {
        System.out.println(brand + " is starting...");
    }
}

class Car extends Vehicle {
    int gearCount;

    void drive() {
        System.out.println(brand + " is driving at " + speed + " km/h with " + gearCount + " gears.");
    }
}

public class Main {
    public static void main(String[] args) {
        Car myCar = new Car();
        myCar.brand = "Toyota";
        myCar.speed = 120;
        myCar.gearCount = 6;

        myCar.start();
        myCar.drive();
    }
}
